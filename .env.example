XAI_API_KEY=xai-REPLACE_ME
GITHUB_TOKEN=

# LinkedIn integration (OAuth 2.0). Required for the Publish / Like / Comment
# buttons. Leave blank to run in manual copy/paste mode.
#
# Create an app at https://www.linkedin.com/developers/apps, add the products
# "Sign In with LinkedIn using OpenID Connect" and "Share on LinkedIn", and add
# LINKEDIN_REDIRECT_URI below to Authorized redirect URLs on the Auth tab.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8765/auth/linkedin/callback

# Token required by POST /ingest. Any opaque string. Leave empty to disable
# the endpoint. Pass it in X-Ingest-Token header from your external systems.
INGEST_TOKEN=
